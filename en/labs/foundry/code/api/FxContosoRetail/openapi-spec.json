{
  "swagger": "2.0",
  "info": {
    "title": "OpenAPI Document on Azure Functions",
    "description": "This is the OpenAPI Document on Azure Functions",
    "version": "1.0.0"
  },
  "host": "localhost:7071",
  "basePath": "/api",
  "schemes": [
    "http"
  ],
  "paths": {
    "/SqlExecutor": {
      "post": {
        "tags": [
          "Data"
        ],
        "summary": "Executes a T-SQL query for customer segments",
        "description": "Receives T-SQL in the body, runs the query against Fabric Warehouse and returns a list with FirstName, LastName, PrimaryEmail and FavoriteCategory.",
        "operationId": "sqlExecutor",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json",
          "text/plain"
        ],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "description": "JSON object with a 'tsql' property containing the query to execute",
            "required": true,
            "schema": {
              "$ref": "#/definitions/sqlExecutorRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Typed results for the customer segment",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/sqlExecutorCustomerRecord"
              }
            }
          },
          "400": {
            "description": "Error message for invalid body or columns different from the expected contract",
            "schema": {
              "type": "string"
            }
          },
          "500": {
            "description": "Error executing the SQL query",
            "schema": {
              "type": "string"
            }
          }
        }
      }
    },
    "/OrdersReporter": {
      "post": {
        "tags": [
          "Reports"
        ],
        "summary": "Generates an HTML orders report",
        "description": "Receives order lines for a customer, generates an HTML report with the details, uploads it to Blob Storage and returns the SAS URL to view or download it.",
        "operationId": "ordersReporter",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json",
          "text/plain"
        ],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "description": "Customer data and order lines to include in the report",
            "required": true,
            "schema": {
              "$ref": "#/definitions/ordersReportRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "JSON object with a 'reportUrl' property containing the SAS URL of the generated report",
            "schema": {
              "type": "object"
            }
          },
          "400": {
            "description": "Error message when the JSON is invalid or contains no orders",
            "schema": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "orderLine": {
      "type": "object",
      "properties": {
        "orderNumber": {
          "type": "string"
        },
        "orderDate": {
          "type": "string"
        },
        "orderLineNumber": {
          "format": "int32",
          "type": "integer"
        },
        "productName": {
          "type": "string"
        },
        "brandName": {
          "type": "string"
        },
        "categoryName": {
          "type": "string"
        },
        "quantity": {
          "format": "double",
          "type": "number"
        },
        "unitPrice": {
          "format": "double",
          "type": "number"
        },
        "lineTotal": {
          "format": "double",
          "type": "number"
        }
      }
    },
    "ordersReportRequest": {
      "type": "object",
      "properties": {
        "customerName": {
          "type": "string"
        },
        "startDate": {
          "type": "string"
        },
        "endDate": {
          "type": "string"
        },
        "orders": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/orderLine"
          }
        }
      }
    },
    "sqlExecutorCustomerRecord": {
      "type": "object",
      "properties": {
        "firstName": {
          "type": "string"
        },
        "lastName": {
          "type": "string"
        },
        "primaryEmail": {
          "type": "string"
        },
        "favoriteCategory": {
          "type": "string"
        }
      }
    },
    "sqlExecutorRequest": {
      "type": "object",
      "properties": {
        "tSql": {
          "type": "string"
        }
      }
    }
  }
}
